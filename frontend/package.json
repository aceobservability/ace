    "@types/d3-force": "^3.0.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
    "lucide-react": "^0.577.0",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
