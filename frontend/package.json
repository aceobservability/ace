{
  "name": "frontend",
  "private": true,
  "version": "0.15.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "type-check": "vue-tsc --noEmit",
    "lint": "biome lint src vite.config.ts",
    "lint:fix": "biome lint --write src vite.config.ts",
    "format": "biome format --write src vite.config.ts",
    "format:check": "biome format src vite.config.ts",
    "lint:dead-code": "knip"
  },
  "dependencies": {
    "@excalidraw/excalidraw": "^0.18.0",
    "@tailwindcss/typography": "^0.5.19",
    "@types/d3-force": "^3.0.10",
    "d3-force": "^3.0.0",
    "dompurify": "^3.3.3",
    "echarts": "^6.0.0",
    "lucide-vue-next": "^1.0.0",
    "marked": "^18.0.2",
    "monaco-editor": "^0.55.1",
    "posthog-js": "^1.363.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "shiki": "^4.0.2",
    "vue": "^3.5.30",
    "vue-echarts": "^8.0.1",
    "vue-router": "^5.0.4",
    "vue3-grid-layout-next": "^1.0.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vitest/coverage-v8": "^4.0.18",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.9.0",
    "happy-dom": "^20.8.4",
    "knip": "^6.0.4",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "vite": "^8.0.4",
    "vitest": "^4.0.18",
    "vue-tsc": "^3.2.6"
  },
  "overrides": {
    "dompurify": "^3.3.3"
  },
  "packageManager": "bun@1.3.12"
}
