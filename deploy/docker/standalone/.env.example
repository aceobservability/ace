# Copy to .env and set JWT_SECRET before starting:
#   cp .env.example .env
#
# Generate a secret:
#   openssl rand -base64 48

JWT_SECRET=

# Optional overrides
# ACE_PORT=8080
# Pin a release tag in production — :latest upgrades silently on pull:
# ACE_STANDALONE_IMAGE=ghcr.io/aceobservability/ace-standalone:v0.1.0
# Change Postgres credentials before exposing this host to a network:
# POSTGRES_USER=ace
# POSTGRES_PASSWORD=change-me
# POSTGRES_DB=ace
